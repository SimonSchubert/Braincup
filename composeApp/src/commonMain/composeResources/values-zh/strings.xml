    <!-- Game types - descriptions -->
    <string name="game_anomaly_puzzle_desc">找出与众不同的图形。考虑每个图形的颜色和形状。</string>
    <string name="game_mental_calculation_desc">跟随数学表达式。将结果作为下一次计算的基础。</string>
    <string name="game_colored_shapes_desc">将正确陈述的分数相加。</string>
    <string name="game_sherlock_calculation_desc">仅使用给定的数字和这些运算符：+ - * / ( ) 来找出如何达到目标。</string>
    <string name="game_chain_calculation_desc">跟随数学表达式。</string>
    <string name="game_fraction_calculation_desc">解决分数问题。</string>
    <string name="game_value_comparison_desc">选择值最大的表达式。</string>
    <string name="game_path_finder_desc">从标记位置开始，按照箭头找到目的地。</string>
    <string name="game_mini_sudoku_desc">填充小网格，使每一行、列和方块都恰好包含每个数字一次。</string>
    <string name="game_visual_memory_desc">记住网格上的形状，然后在计时结束后识别隐藏的形状。</string>
    <string name="game_pattern_sequence_desc">通过寻找重复的形状、颜色和旋转，找出图案中的下一个图形。</string>
    <string name="game_ghost_grid_desc">观察方格逐个亮起，然后按相同顺序点击它们。</string>
    <string name="game_color_confusion_desc">点击所有文字与字体颜色匹配的单元格，然后按完成。</string>
    <string name="game_orbit_tracker_desc">观察高亮的球，然后在它们移动时追踪。停止后选择最初的目标。</string>
    <string name="game_flash_crowd_desc">每侧短暂闪现圆点。点击圆点更多的一侧。不要数 — 相信你的直觉！</string>
    <string name="game_schulte_table_desc">尽快按1到N的顺序点击数字。</string>
    <string name="game_schulte_instruction">按顺序点击数字：1、2、3……</string>
    <string name="game_mini_chess_desc">以白方完成棋局。在 CPU 将死你之前将死它。</string>
    <string name="game_lights_out_desc">关掉所有灯。每次点击会切换该格和四个相邻格。</string>
    <string name="game_sliding_puzzle_desc">将方块滑入空格,使它们按顺序排列。</string>
    <string name="game_shikaku_desc">将整个网格划分为矩形。每个矩形必须正好包含一个数字,且等于它的面积。</string>
    <string name="game_shikaku_howto">拖动以绘制矩形。点按矩形即可移除。</string>
    <string name="game_nurikabe_desc">涂格子在带数字的岛屿周围筑成海。每个岛屿的相连格子数必须等于它的数字，海必须连成一片，且不能有任何2x2的方块。</string>
    <string name="game_nurikabe_howto">点按或拖动来涂海。点按已涂的格子可清除。</string>
    <string name="game_cat_queens_desc">在每一行、每一列和每个颜色区域中各放一只猫。任意两只猫不能相邻，连对角线也不行。</string>
    <string name="game_cat_queens_howto">点按格子来放置或移除猫。</string>
    <string name="game_knot_desc">用线把每一对同色圆点连接起来。线不能交叉，且必须填满每个格子。</string>
    <string name="game_knot_howto">从圆点拖动来画出线条。点按线条可清除。</string>
