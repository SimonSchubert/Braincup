    <!-- Game types - descriptions -->
    <string name="game_anomaly_puzzle_desc">Tìm hình khác biệt. Xem xét cả màu sắc và hình dạng của mỗi hình.</string>
    <string name="game_mental_calculation_desc">Theo dõi các biểu thức toán học. Sử dụng kết quả làm cơ sở cho phép tính tiếp theo.</string>
    <string name="game_colored_shapes_desc">Cộng điểm từ các phát biểu đúng.</string>
    <string name="game_sherlock_calculation_desc">Tìm cách đạt mục tiêu chỉ bằng các số đã cho và các toán tử này: + - * / ( ).</string>
    <string name="game_chain_calculation_desc">Theo dõi các biểu thức toán học.</string>
    <string name="game_fraction_calculation_desc">Giải các phân số.</string>
    <string name="game_value_comparison_desc">Chọn biểu thức có giá trị cao nhất.</string>
    <string name="game_path_finder_desc">Bắt đầu từ vị trí đánh dấu và đi theo các mũi tên để tìm đích đến.</string>
    <string name="game_mini_sudoku_desc">Điền vào lưới nhỏ sao cho mỗi hàng, cột và khối chứa mỗi số đúng một lần.</string>
    <string name="game_visual_memory_desc">Ghi nhớ các hình trên lưới, sau đó xác định hình ẩn sau khi hết giờ.</string>
    <string name="game_pattern_sequence_desc">Tìm hình tiếp theo trong mẫu bằng cách tìm kiếm các hình dạng, màu sắc và phép quay lặp lại.</string>
    <string name="game_ghost_grid_desc">Xem các ô sáng lên từng cái một, sau đó chạm vào chúng theo cùng thứ tự.</string>
    <string name="game_color_confusion_desc">Chạm vào tất cả ô mà từ khớp với màu phông chữ, sau đó nhấn Xong.</string>
    <string name="game_orbit_tracker_desc">Quan sát các quả bóng được đánh dấu, sau đó theo dõi chúng khi di chuyển. Chọn các mục tiêu ban đầu sau khi dừng lại.</string>
    <string name="game_flash_crowd_desc">Các chấm nhấp nháy ngắn ở mỗi bên. Chạm vào bên có nhiều chấm hơn. Đừng đếm — hãy tin vào trực giác!</string>
    <string name="game_schulte_table_desc">Chạm các số theo thứ tự từ 1 trở lên nhanh nhất có thể.</string>
    <string name="game_schulte_instruction">Chạm các số theo thứ tự: 1, 2, 3...</string>
    <string name="game_mini_chess_desc">Hoàn thành ván cờ với quân trắng. Chiếu hết CPU trước khi nó chiếu hết bạn.</string>
    <string name="game_lights_out_desc">Tắt mọi đèn. Mỗi cú chạm sẽ đổi trạng thái ô đó và bốn ô lân cận.</string>
    <string name="game_sliding_puzzle_desc">Trượt các ô vào chỗ trống để xếp chúng theo thứ tự.</string>
