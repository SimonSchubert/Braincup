    <!-- Game types - descriptions -->
    <string name="game_anomaly_puzzle_desc">Temukan gambar yang berbeda. Pertimbangkan warna dan bentuk dari setiap gambar.</string>
    <string name="game_mental_calculation_desc">Ikuti ekspresi matematika. Gunakan hasilnya sebagai dasar untuk perhitungan berikutnya.</string>
    <string name="game_colored_shapes_desc">Jumlahkan poin dari pernyataan yang benar.</string>
    <string name="game_sherlock_calculation_desc">Temukan cara mencapai target hanya dengan angka yang diberikan dan operator ini: + - * / ( ).</string>
    <string name="game_chain_calculation_desc">Ikuti ekspresi matematika.</string>
    <string name="game_fraction_calculation_desc">Selesaikan pecahan.</string>
    <string name="game_value_comparison_desc">Pilih ekspresi dengan nilai tertinggi.</string>
    <string name="game_path_finder_desc">Mulai dari posisi yang ditandai dan ikuti panah untuk menemukan tujuan.</string>
    <string name="game_mini_sudoku_desc">Isi kotak kecil agar setiap baris, kolom dan blok berisi setiap angka tepat satu kali.</string>
    <string name="game_visual_memory_desc">Hafalkan bentuk-bentuk di kotak, lalu identifikasi bentuk tersembunyi setelah waktu habis.</string>
    <string name="game_pattern_sequence_desc">Temukan gambar berikutnya dalam pola dengan mencari bentuk, warna, dan rotasi yang berulang.</string>
    <string name="game_ghost_grid_desc">Perhatikan ubin menyala satu per satu, lalu ketuk dalam urutan yang sama.</string>
    <string name="game_color_confusion_desc">Ketuk semua sel yang katanya cocok dengan warna hurufnya, lalu tekan Selesai.</string>
    <string name="game_orbit_tracker_desc">Perhatikan bola-bola yang disorot, lalu lacak pergerakannya. Pilih target asli setelah berhenti.</string>
    <string name="game_flash_crowd_desc">Titik-titik berkedip sebentar di setiap sisi. Ketuk sisi yang memiliki lebih banyak titik. Jangan menghitung — percaya insting Anda!</string>
    <string name="game_schulte_table_desc">Ketuk angka secara berurutan dari 1 secepat mungkin.</string>
    <string name="game_schulte_instruction">Ketuk angka secara berurutan: 1, 2, 3...</string>
