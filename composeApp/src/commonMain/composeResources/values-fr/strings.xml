    <!-- Game types - descriptions -->
    <string name="game_anomaly_puzzle_desc">Trouvez la figure qui se démarque. Considérez à la fois la couleur et la forme de chaque figure.</string>
    <string name="game_mental_calculation_desc">Suivez les expressions mathématiques. Utilisez le résultat comme base pour le calcul suivant.</string>
    <string name="game_colored_shapes_desc">Additionnez les points des affirmations correctes.</string>
    <string name="game_sherlock_calculation_desc">Trouvez comment atteindre l'objectif en utilisant uniquement les nombres donnés et ces opérateurs : + - * / ( ).</string>
    <string name="game_chain_calculation_desc">Suivez les expressions mathématiques.</string>
    <string name="game_fraction_calculation_desc">Résolvez les fractions.</string>
    <string name="game_value_comparison_desc">Sélectionnez l'expression ayant la valeur la plus élevée.</string>
    <string name="game_path_finder_desc">Commencez à la position marquée et suivez les flèches pour trouver la destination.</string>
    <string name="game_mini_sudoku_desc">Remplis la petite grille pour que chaque ligne, colonne et bloc contienne chaque chiffre exactement une fois.</string>
    <string name="game_visual_memory_desc">Mémorisez les formes sur la grille, puis identifiez la forme cachée après la fin du chronomètre.</string>
    <string name="game_pattern_sequence_desc">Trouvez la figure suivante dans le motif en cherchant les formes, couleurs et rotations qui se répètent.</string>
    <string name="game_ghost_grid_desc">Regardez les cases s'allumer une par une, puis touchez-les dans le même ordre.</string>
    <string name="game_color_confusion_desc">Touchez toutes les cellules où le mot correspond à la couleur de la police, puis appuyez sur Terminé.</string>
    <string name="game_orbit_tracker_desc">Observez les balles en surbrillance, puis suivez-les pendant leur déplacement. Sélectionnez les cibles originales après l'arrêt.</string>
    <string name="game_flash_crowd_desc">Des points clignotent brièvement de chaque côté. Touchez le côté qui avait plus de points. Ne comptez pas — fiez-vous à votre instinct !</string>
    <string name="game_schulte_table_desc">Touche les chiffres dans l'ordre à partir de 1 le plus vite possible.</string>
    <string name="game_schulte_instruction">Touche les chiffres dans l'ordre : 1, 2, 3...</string>
    <string name="game_mini_chess_desc">Termine le scénario d'échecs avec les blancs. Mets la CPU échec et mat avant qu'elle ne te mette.</string>
    <string name="game_lights_out_desc">Éteins toutes les lumières. Chaque tap inverse la cellule et ses quatre voisines.</string>
    <string name="game_sliding_puzzle_desc">Glisse les tuiles dans l'espace vide pour les mettre en ordre.</string>
