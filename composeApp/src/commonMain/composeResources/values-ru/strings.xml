    <!-- Game types - descriptions -->
    <string name="game_anomaly_puzzle_desc">Найдите фигуру, которая выделяется. Учитывайте как цвет, так и форму каждой фигуры.</string>
    <string name="game_mental_calculation_desc">Следуйте математическим выражениям. Используйте результат как основу для следующего вычисления.</string>
    <string name="game_colored_shapes_desc">Сложите очки за правильные утверждения.</string>
    <string name="game_sherlock_calculation_desc">Найдите способ достичь цели, используя только данные числа и операторы: + - * / ( ).</string>
