    <!-- Game types - descriptions -->
    <string name="game_anomaly_puzzle_desc">Vind de figuur die opvalt. Let op zowel de kleur als de vorm van elke figuur.</string>
    <string name="game_mental_calculation_desc">Volg de wiskundige uitdrukkingen. Gebruik het resultaat als basis voor de volgende berekening.</string>
    <string name="game_colored_shapes_desc">Tel de punten van de juiste uitspraken op.</string>
    <string name="game_sherlock_calculation_desc">Vind hoe je het doel kunt bereiken met alleen de gegeven getallen en deze operatoren: + - * / ( ).</string>
    <string name="game_chain_calculation_desc">Volg de wiskundige uitdrukkingen.</string>
    <string name="game_fraction_calculation_desc">Los de breuken op.</string>
    <string name="game_value_comparison_desc">Selecteer de uitdrukking met de hoogste waarde.</string>
    <string name="game_path_finder_desc">Begin op de gemarkeerde positie en volg de pijlen om de bestemming te vinden.</string>
    <string name="game_mini_sudoku_desc">Vul het kleine raster in zodat elke rij, kolom en blok elk getal precies één keer bevat.</string>
    <string name="game_visual_memory_desc">Onthoud de vormen op het raster en identificeer vervolgens de verborgen vorm nadat de timer is afgelopen.</string>
    <string name="game_pattern_sequence_desc">Vind de volgende figuur in het patroon door te zoeken naar herhalende vormen, kleuren en rotaties.</string>
    <string name="game_ghost_grid_desc">Kijk hoe de tegels één voor één oplichten en tik ze daarna in dezelfde volgorde aan.</string>
    <string name="game_color_confusion_desc">Tik alle cellen aan waar het woord overeenkomt met de letterkleur en druk dan op Klaar.</string>
    <string name="game_orbit_tracker_desc">Kijk naar de gemarkeerde ballen en volg ze terwijl ze bewegen. Selecteer de oorspronkelijke doelen nadat ze stoppen.</string>
    <string name="game_flash_crowd_desc">Stippen flitsen kort aan elke kant. Tik op de kant met meer stippen. Tel niet — vertrouw op je instinct!</string>
    <string name="game_schulte_table_desc">Tik de nummers zo snel mogelijk op volgorde vanaf 1.</string>
    <string name="game_schulte_instruction">Tik de nummers op volgorde: 1, 2, 3...</string>
    <string name="game_mini_chess_desc">Voltooi het schaakscenario als wit. Geef de CPU schaakmat voordat hij jou schaakmat geeft.</string>
    <string name="game_lights_out_desc">Schakel alle lichten uit. Elke tik wisselt de cel en zijn vier buren om.</string>
    <string name="game_sliding_puzzle_desc">Schuif tegels in de lege ruimte om ze op volgorde te zetten.</string>
