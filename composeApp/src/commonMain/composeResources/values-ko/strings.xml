    <!-- Game types - descriptions -->
    <string name="game_anomaly_puzzle_desc">다른 도형을 찾으세요. 각 도형의 색상과 모양을 모두 고려하세요.</string>
    <string name="game_mental_calculation_desc">수학 표현식을 따르세요. 결과를 다음 계산의 기초로 사용하세요.</string>
    <string name="game_colored_shapes_desc">올바른 문장의 점수를 합산하세요.</string>
    <string name="game_sherlock_calculation_desc">주어진 숫자와 연산자만 사용하여 목표에 도달하는 방법을 찾으세요: + - * / ( ).</string>
    <string name="game_chain_calculation_desc">수학 표현식을 따르세요.</string>
    <string name="game_fraction_calculation_desc">분수를 풀어보세요.</string>
    <string name="game_value_comparison_desc">가장 높은 값을 가진 표현식을 선택하세요.</string>
    <string name="game_path_finder_desc">표시된 위치에서 시작하여 화살표를 따라 목적지를 찾으세요.</string>
    <string name="game_mini_sudoku_desc">작은 그리드를 채워 각 행, 열, 블록에 각 숫자가 정확히 한 번씩 들어가도록 하세요.</string>
    <string name="game_visual_memory_desc">그리드의 도형을 기억한 후 타이머가 끝나면 숨겨진 도형을 식별하세요.</string>
    <string name="game_pattern_sequence_desc">반복되는 모양, 색상, 회전을 찾아 패턴의 다음 도형을 찾으세요.</string>
    <string name="game_ghost_grid_desc">타일이 하나씩 켜지는 것을 보고, 같은 순서로 탭하세요.</string>
    <string name="game_color_confusion_desc">단어가 글꼴 색상과 일치하는 모든 셀을 탭한 다음 완료를 누르세요.</string>
    <string name="game_orbit_tracker_desc">강조된 공을 관찰한 후 움직임을 추적하세요. 멈춘 후 원래 목표물을 선택하세요.</string>
    <string name="game_flash_crowd_desc">각 쪽에 점이 잠깐 깜빡입니다. 점이 더 많았던 쪽을 탭하세요. 세지 마세요 — 직감을 믿으세요!</string>
    <string name="game_schulte_table_desc">1부터 순서대로 숫자를 최대한 빠르게 탭하세요.</string>
    <string name="game_schulte_instruction">숫자를 순서대로 탭: 1, 2, 3...</string>
    <string name="game_mini_chess_desc">백을 잡고 체스 시나리오를 완료하세요. CPU가 당신을 메이트하기 전에 메이트하세요.</string>
    <string name="game_lights_out_desc">모든 빛을 끄세요. 탭할 때마다 해당 셀과 인접한 네 셀이 토글됩니다.</string>
