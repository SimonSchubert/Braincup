    <string name="game_anomaly_puzzle_desc">หารูปที่แตกต่าง พิจารณาทั้งสีและรูปร่างของแต่ละรูป</string>
    <string name="game_mental_calculation_desc">ทำตามนิพจน์คณิตศาสตร์ ใช้ผลลัพธ์เป็นฐานสำหรับการคำนวณถัดไป</string>
    <string name="game_colored_shapes_desc">รวมคะแนนจากข้อความที่ถูกต้อง</string>
    <string name="game_sherlock_calculation_desc">หาวิธีไปถึงเป้าหมายโดยใช้เฉพาะตัวเลขที่กำหนดและตัวดำเนินการเหล่านี้: + - * / ( )</string>
    <string name="game_chain_calculation_desc">ทำตามนิพจน์คณิตศาสตร์</string>
    <string name="game_fraction_calculation_desc">แก้เศษส่วน</string>
    <string name="game_value_comparison_desc">เลือกนิพจน์ที่มีค่าสูงสุด</string>
    <string name="game_path_finder_desc">เริ่มจากตำแหน่งที่ทำเครื่องหมายและตามลูกศรเพื่อหาจุดหมาย</string>
    <string name="game_mini_sudoku_desc">เติมตารางเล็กให้แต่ละแถว คอลัมน์ และบล็อก มีตัวเลขแต่ละตัวพอดีหนึ่งครั้ง</string>
    <string name="game_visual_memory_desc">จำรูปร่างบนตาราง แล้วระบุรูปร่างที่ซ่อนอยู่หลังจากหมดเวลา</string>
    <string name="game_pattern_sequence_desc">ค้นหารูปถัดไปในรูปแบบโดยมองหารูปร่าง สี และการหมุนที่ซ้ำกัน</string>
    <string name="game_ghost_grid_desc">ดูช่องสว่างขึ้นทีละช่อง แล้วแตะตามลำดับเดิม</string>
    <string name="game_color_confusion_desc">แตะเซลล์ทั้งหมดที่คำตรงกับสีตัวอักษร แล้วกดเสร็จ</string>
    <string name="game_orbit_tracker_desc">ดูลูกบอลที่ถูกไฮไลท์ แล้วติดตามขณะเคลื่อนที่ เลือกเป้าหมายเดิมหลังจากหยุด</string>
    <string name="game_flash_crowd_desc">จุดจะกะพริบสั้นๆ แต่ละด้าน แตะด้านที่มีจุดมากกว่า อย่านับ — เชื่อสัญชาตญาณของคุณ!</string>
    <string name="game_schulte_table_desc">แตะตัวเลขตามลำดับเริ่มจาก 1 ให้เร็วที่สุดเท่าที่ทำได้</string>
    <string name="game_schulte_instruction">แตะตัวเลขตามลำดับ: 1, 2, 3...</string>
    <string name="game_mini_chess_desc">จบสถานการณ์หมากรุกในฐานะฝ่ายขาว รุกฆาตซีพียูก่อนที่มันจะรุกฆาตคุณ</string>
    <string name="game_lights_out_desc">ปิดไฟทุกดวง การแตะแต่ละครั้งจะสลับช่องและช่องเพื่อนบ้านทั้งสี่</string>
