    <!-- Game types - descriptions -->
    <string name="game_anomaly_puzzle_desc">اعثر على الشكل المختلف. ضع في اعتبارك لون وشكل كل عنصر.</string>
    <string name="game_mental_calculation_desc">اتبع التعبيرات الرياضية. استخدم النتيجة كأساس للحساب التالي.</string>
    <string name="game_colored_shapes_desc">اجمع نقاط العبارات الصحيحة.</string>
    <string name="game_sherlock_calculation_desc">اكتشف كيفية الوصول إلى الهدف باستخدام الأرقام المعطاة وهذه العمليات فقط: + - * / ( ).</string>
    <string name="game_chain_calculation_desc">اتبع التعبيرات الرياضية.</string>
    <string name="game_fraction_calculation_desc">حل الكسور.</string>
    <string name="game_value_comparison_desc">اختر التعبير ذو القيمة الأعلى.</string>
    <string name="game_path_finder_desc">ابدأ من الموقع المحدد واتبع الأسهم للوصول إلى الوجهة.</string>
    <string name="game_mini_sudoku_desc">املأ الشبكة الصغيرة بحيث يحتوي كل صف وعمود وكتلة على كل رقم مرة واحدة بالضبط.</string>
    <string name="game_visual_memory_desc">احفظ الأشكال على الشبكة، ثم حدد الشكل المخفي بعد انتهاء المؤقت.</string>
    <string name="game_pattern_sequence_desc">اعثر على الشكل التالي في النمط من خلال البحث عن الأشكال والألوان والدورانات المتكررة.</string>
    <string name="game_ghost_grid_desc">شاهد المربعات تضيء واحدة تلو الأخرى، ثم اضغط عليها بنفس الترتيب.</string>
    <string name="game_color_confusion_desc">اضغط على جميع الخلايا التي تتطابق فيها الكلمة مع لون الخط، ثم اضغط تم.</string>
    <string name="game_orbit_tracker_desc">شاهد الكرات المميزة، ثم تتبعها أثناء تحركها. حدد الأهداف الأصلية بعد توقفها.</string>
    <string name="game_flash_crowd_desc">تومض النقاط لفترة وجيزة على كل جانب. انقر على الجانب الذي يحتوي على نقاط أكثر. لا تعد — ثق بحدسك!</string>
    <string name="game_schulte_table_desc">اضغط الأرقام بالترتيب من 1 فصاعداً بأسرع ما يمكن.</string>
    <string name="game_schulte_instruction">اضغط الأرقام بالترتيب: 1، 2، 3...</string>
    <string name="game_mini_chess_desc">أنه سيناريو الشطرنج بالأبيض. أوقع كش ملك على الحاسوب قبل أن يوقعه عليك.</string>
    <string name="game_lights_out_desc">أطفئ كل ضوء. كل نقرة تقلب الخلية وجيرانها الأربعة.</string>
    <string name="game_sliding_puzzle_desc">حرّك القطع إلى المساحة الفارغة لترتيبها.</string>
