    <!-- Game types - descriptions -->
    <string name="game_anomaly_puzzle_desc">Trova la figura che si distingue. Considera sia il colore che la forma di ogni figura.</string>
    <string name="game_mental_calculation_desc">Segui le espressioni matematiche. Usa il risultato come base per il calcolo successivo.</string>
    <string name="game_colored_shapes_desc">Somma i punti delle affermazioni corrette.</string>
    <string name="game_sherlock_calculation_desc">Trova come raggiungere l'obiettivo usando solo i numeri dati e questi operatori: + - * / ( ).</string>
    <string name="game_chain_calculation_desc">Segui le espressioni matematiche.</string>
    <string name="game_fraction_calculation_desc">Risolvi le frazioni.</string>
    <string name="game_value_comparison_desc">Seleziona l'espressione con il valore più alto.</string>
    <string name="game_path_finder_desc">Inizia dalla posizione segnata e segui le frecce per trovare la destinazione.</string>
    <string name="game_mini_sudoku_desc">Riempi la piccola griglia in modo che ogni riga, colonna e blocco contenga ogni numero esattamente una volta.</string>
    <string name="game_visual_memory_desc">Memorizza le forme sulla griglia, poi identifica la forma nascosta dopo la fine del timer.</string>
    <string name="game_pattern_sequence_desc">Trova la figura successiva nello schema cercando forme, colori e rotazioni che si ripetono.</string>
    <string name="game_ghost_grid_desc">Osserva le caselle illuminarsi una alla volta, poi toccale nello stesso ordine.</string>
    <string name="game_color_confusion_desc">Tocca tutte le celle in cui la parola corrisponde al colore del carattere, poi premi Fatto.</string>
    <string name="game_orbit_tracker_desc">Osserva le palle evidenziate, poi seguile mentre si muovono. Seleziona i bersagli originali dopo che si fermano.</string>
    <string name="game_flash_crowd_desc">I punti lampeggiano brevemente su ogni lato. Tocca il lato che aveva più punti. Non contare — fidati del tuo istinto!</string>
    <string name="game_schulte_table_desc">Tocca i numeri in ordine dal 1 in su il più velocemente possibile.</string>
    <string name="game_schulte_instruction">Tocca i numeri in ordine: 1, 2, 3...</string>
    <string name="game_mini_chess_desc">Finish the chess scenario as white. Checkmate the CPU before it checkmates you.</string>
