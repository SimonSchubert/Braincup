    <!-- Game types - descriptions -->
    <string name="game_anomaly_puzzle_desc">Znajdź figurę, która się wyróżnia. Weź pod uwagę zarówno kolor, jak i kształt każdej figury.</string>
    <string name="game_mental_calculation_desc">Śledź wyrażenia matematyczne. Użyj wyniku jako podstawy do następnego obliczenia.</string>
    <string name="game_colored_shapes_desc">Zsumuj punkty z poprawnych stwierdzeń.</string>
    <string name="game_sherlock_calculation_desc">Znajdź sposób na osiągnięcie celu używając tylko podanych liczb i tych operatorów: + - * / ( ).</string>
    <string name="game_chain_calculation_desc">Śledź wyrażenia matematyczne.</string>
    <string name="game_fraction_calculation_desc">Rozwiąż ułamki.</string>
    <string name="game_value_comparison_desc">Wybierz wyrażenie o najwyższej wartości.</string>
    <string name="game_path_finder_desc">Zacznij od zaznaczonej pozycji i podążaj za strzałkami, aby znaleźć cel.</string>
    <string name="game_mini_sudoku_desc">Wypełnij małą siatkę tak, aby każdy wiersz, kolumna i blok zawierały każdą liczbę dokładnie raz.</string>
    <string name="game_visual_memory_desc">Zapamiętaj kształty na siatce, a następnie zidentyfikuj ukryty kształt po upływie czasu.</string>
    <string name="game_pattern_sequence_desc">Znajdź następną figurę we wzorze, szukając powtarzających się kształtów, kolorów i obrotów.</string>
    <string name="game_ghost_grid_desc">Obserwuj, jak kafelki zapalają się jeden po drugim, a następnie dotknij ich w tej samej kolejności.</string>
    <string name="game_color_confusion_desc">Dotknij wszystkich komórek, w których słowo odpowiada kolorowi czcionki, a następnie naciśnij Gotowe.</string>
    <string name="game_orbit_tracker_desc">Obserwuj podświetlone kule, a następnie śledź je podczas ruchu. Wybierz oryginalne cele po zatrzymaniu.</string>
    <string name="game_flash_crowd_desc">Kropki migają krótko po każdej stronie. Dotknij strony, która miała więcej kropek. Nie licz — zaufaj swojemu instynktowi!</string>
    <string name="game_schulte_table_desc">Stukaj liczby w kolejności od 1 tak szybko, jak potrafisz.</string>
    <string name="game_schulte_instruction">Stukaj liczby w kolejności: 1, 2, 3...</string>
    <string name="game_mini_chess_desc">Zakończ scenariusz szachowy jako białe. Daj mata CPU, zanim ona da mata tobie.</string>
    <string name="game_lights_out_desc">Wyłącz wszystkie światła. Każde dotknięcie przełącza komórkę i jej czterech sąsiadów.</string>
    <string name="game_sliding_puzzle_desc">Przesuwaj kafelki na puste pole, aby ułożyć je po kolei.</string>
