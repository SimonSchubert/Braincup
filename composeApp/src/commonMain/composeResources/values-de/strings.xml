    <!-- Game types - descriptions -->
    <string name="game_anomaly_puzzle_desc">Finde die Figur, die heraussticht. Beachte sowohl Farbe als auch Form jeder Figur.</string>
    <string name="game_mental_calculation_desc">Folge den mathematischen Ausdrücken. Verwende das Ergebnis als Grundlage für die nächste Berechnung.</string>
    <string name="game_colored_shapes_desc">Addiere die Punkte der richtigen Aussagen.</string>
    <string name="game_sherlock_calculation_desc">Finde heraus, wie du das Ziel nur mit den gegebenen Zahlen und diesen Operatoren erreichst: + - * / ( ).</string>
    <string name="game_chain_calculation_desc">Folge den mathematischen Ausdrücken.</string>
    <string name="game_fraction_calculation_desc">Löse die Brüche.</string>
    <string name="game_value_comparison_desc">Wähle den Ausdruck mit dem höchsten Wert.</string>
    <string name="game_path_finder_desc">Beginne an der markierten Position und folge den Pfeilen, um das Ziel zu finden.</string>
    <string name="game_mini_sudoku_desc">Fülle das kleine Gitter so aus, dass jede Zeile, Spalte und jeder Block jede Zahl genau einmal enthält.</string>
    <string name="game_visual_memory_desc">Merke dir die Formen im Gitter und identifiziere die versteckte Form nach Ablauf des Timers.</string>
    <string name="game_pattern_sequence_desc">Finde die nächste Figur im Muster, indem du nach sich wiederholenden Formen, Farben und Drehungen suchst.</string>
    <string name="game_ghost_grid_desc">Beobachte, wie die Felder nacheinander aufleuchten, und tippe sie in der gleichen Reihenfolge an.</string>
    <string name="game_color_confusion_desc">Tippe alle Felder an, bei denen das Wort mit seiner Schriftfarbe übereinstimmt, und drücke dann Fertig.</string>
    <string name="game_orbit_tracker_desc">Beobachte die markierten Kugeln und verfolge sie während der Bewegung. Wähle die ursprünglichen Ziele nach dem Stillstand aus.</string>
    <string name="game_flash_crowd_desc">Punkte blinken kurz auf jeder Seite auf. Tippe auf die Seite mit mehr Punkten. Zähle nicht — vertraue deinem Instinkt!</string>
    <string name="game_schulte_table_desc">Tippe die Zahlen so schnell wie möglich der Reihe nach von 1 aufwärts an.</string>
    <string name="game_schulte_instruction">Tippe die Zahlen der Reihe nach: 1, 2, 3...</string>
    <string name="game_mini_chess_desc">Finish the chess scenario as white. Checkmate the CPU before it checkmates you.</string>
    <string name="game_lights_out_desc">Turn off every light. Each tap toggles the cell and its four neighbours.</string>
    <string name="game_lights_out_instruction">Turn off all the lights</string>
    <string name="game_sliding_puzzle_desc">Slide tiles into the empty space to put them in order.</string>
    <string name="game_sliding_puzzle_instruction">Tap a tile next to the empty cell to slide it</string>
