    <!-- Game types - descriptions -->
    <string name="game_anomaly_puzzle_desc">Farklı olan şekli bulun. Her şeklin hem rengini hem de biçimini göz önünde bulundurun.</string>
    <string name="game_mental_calculation_desc">Matematiksel ifadeleri takip edin. Sonucu bir sonraki hesaplama için temel olarak kullanın.</string>
    <string name="game_colored_shapes_desc">Doğru ifadelerin puanlarını toplayın.</string>
    <string name="game_sherlock_calculation_desc">Yalnızca verilen sayıları ve şu operatörleri kullanarak hedefe nasıl ulaşacağınızı bulun: + - * / ( ).</string>
    <string name="game_chain_calculation_desc">Matematiksel ifadeleri takip edin.</string>
    <string name="game_fraction_calculation_desc">Kesirleri çözün.</string>
    <string name="game_value_comparison_desc">En yüksek değere sahip ifadeyi seçin.</string>
    <string name="game_path_finder_desc">İşaretli konumdan başlayın ve hedefi bulmak için okları takip edin.</string>
    <string name="game_mini_sudoku_desc">Küçük ızgarayı her satır, sütun ve bloğun her sayıyı tam olarak bir kez içerecek şekilde doldurun.</string>
    <string name="game_visual_memory_desc">Izgaradaki şekilleri ezberleyin, ardından süre dolduktan sonra gizli şekli belirleyin.</string>
    <string name="game_pattern_sequence_desc">Tekrarlayan şekilleri, renkleri ve döndürmeleri arayarak desendeki bir sonraki şekli bulun.</string>
    <string name="game_ghost_grid_desc">Karelerin tek tek yanmasını izleyin, ardından aynı sırayla dokunun.</string>
    <string name="game_color_confusion_desc">Kelimenin yazı tipi rengiyle eşleştiği tüm hücrelere dokunun, ardından Bitti'ye basın.</string>
    <string name="game_orbit_tracker_desc">Vurgulanan topları izleyin, ardından hareket ederken takip edin. Durduktan sonra orijinal hedefleri seçin.</string>
    <string name="game_flash_crowd_desc">Her iki tarafta noktalar kısa süre yanıp söner. Daha fazla noktası olan tarafa dokunun. Saymayın — içgüdünüze güvenin!</string>
    <string name="game_schulte_table_desc">Sayılara 1'den başlayarak sırayla mümkün olduğunca hızlı dokun.</string>
    <string name="game_schulte_instruction">Sayılara sırayla dokun: 1, 2, 3...</string>
    <string name="game_mini_chess_desc">Beyazlarla satranç senaryosunu bitir. CPU sana mat etmeden önce ona mat et.</string>
    <string name="game_lights_out_desc">Tüm ışıkları söndür. Her dokunuş, hücreyi ve dört komşusunu değiştirir.</string>
    <string name="game_sliding_puzzle_desc">Karoları boş alana kaydırarak sıraya diz.</string>
    <string name="game_tower_of_hanoi_desc">Tüm yığını sağ çubuğa taşı. Her seferinde yalnızca bir disk ve asla büyüğünü küçüğünün üstüne koyma.</string>
    <string name="game_shikaku_desc">Tüm ızgarayı dikdörtgenlere böl. Her dikdörtgende, alanına eşit tam olarak bir sayı bulunmalıdır.</string>
    <string name="game_shikaku_howto">Dikdörtgen çizmek için sürükle. Kaldırmak için bir dikdörtgene dokun.</string>
    <string name="game_nurikabe_desc">Numaralı adaların çevresinde denizi oluşturmak için hücreleri boyayın. Her ada, sayısı kadar bağlı hücreye sahip olmalı, deniz bağlantılı olmalı ve hiçbir 2x2 blok içermemelidir.</string>
    <string name="game_nurikabe_howto">Denizi boyamak için dokunun veya sürükleyin. Boyalı bir hücreyi temizlemek için ona dokunun.</string>
    <string name="game_cat_queens_desc">Her satıra, her sütuna ve her renk bölgesine bir kedi yerleştir. İki kedi birbirine dokunamaz, çapraz olarak da.</string>
    <string name="game_cat_queens_howto">Kedi yerleştirmek veya kaldırmak için bir hücreye dokun.</string>
    <string name="game_knot_desc">Her renkli nokta çiftini bir yolla bağla. Yollar birbirini kesmemeli ve birlikte her hücreyi kapsamalıdır.</string>
    <string name="game_knot_howto">Yolu çizmek için bir noktadan sürükle. Yolu silmek için üzerine dokun.</string>
    <string name="game_solo_chess_desc">Yalnızca şah kalana kadar taşları teker teker al. Her hamle bir taş almalı ve hiçbir taş ikiden fazla alamaz.</string>
    <string name="game_solo_chess_howto">Bir taşa, sonra alabileceği bir taşa dokun. Şah alınamaz ve son kalan taş olmalıdır.</string>
