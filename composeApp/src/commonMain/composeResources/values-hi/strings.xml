    <!-- Game types - descriptions -->
    <string name="game_anomaly_puzzle_desc">उस आकृति को खोजें जो अलग दिखती है। प्रत्येक आकृति के रंग और आकार दोनों पर विचार करें।</string>
    <string name="game_mental_calculation_desc">गणितीय व्यंजकों का पालन करें। परिणाम को अगली गणना के आधार के रूप में उपयोग करें।</string>
    <string name="game_colored_shapes_desc">सही कथनों के अंक जोड़ें।</string>
    <string name="game_sherlock_calculation_desc">केवल दिए गए नंबरों और इन ऑपरेटरों का उपयोग करके लक्ष्य तक पहुंचने का तरीका खोजें: + - * / ( )।</string>
    <string name="game_chain_calculation_desc">गणितीय व्यंजकों का पालन करें।</string>
    <string name="game_fraction_calculation_desc">भिन्नों को हल करें।</string>
    <string name="game_value_comparison_desc">सबसे अधिक मूल्य वाले व्यंजक का चयन करें।</string>
    <string name="game_path_finder_desc">चिह्नित स्थान से शुरू करें और गंतव्य खोजने के लिए तीरों का पालन करें।</string>
    <string name="game_grid_solver_desc">लुप्त संख्याएं भरें ताकि प्रत्येक पंक्ति और स्तंभ का योग दिए गए कुल के बराबर हो।</string>
    <string name="game_visual_memory_desc">ग्रिड पर आकृतियों को याद करें, फिर टाइमर समाप्त होने के बाद छिपी हुई आकृति की पहचान करें।</string>
    <string name="game_pattern_sequence_desc">दोहराए जाने वाले आकार, रंग और घुमाव खोजकर पैटर्न में अगली आकृति खोजें।</string>
    <string name="game_ghost_grid_desc">टाइलों को एक-एक करके जलते हुए देखें, फिर उन्हें उसी क्रम में टैप करें।</string>
    <string name="game_color_confusion_desc">उन सभी सेल को टैप करें जहाँ शब्द फ़ॉन्ट रंग से मेल खाता है, फिर पूर्ण दबाएँ।</string>
    <string name="game_orbit_tracker_desc">हाइलाइट की गई गेंदों को देखें, फिर उनकी गति को ट्रैक करें। रुकने के बाद मूल लक्ष्यों को चुनें।</string>
    <string name="game_flash_crowd_desc">हर तरफ कुछ देर के लिए बिंदु चमकते हैं। जिस तरफ अधिक बिंदु थे, उसे टैप करें। गिनें नहीं — अपनी अंतर्ज्ञान पर भरोसा करें!</string>
