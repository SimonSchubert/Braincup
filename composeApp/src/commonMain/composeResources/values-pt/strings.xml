    <!-- Game types - descriptions -->
    <string name="game_anomaly_puzzle_desc">Encontre a figura que se destaca. Considere tanto a cor quanto a forma de cada figura.</string>
    <string name="game_mental_calculation_desc">Siga as expressões matemáticas. Use o resultado como base para o próximo cálculo.</string>
    <string name="game_colored_shapes_desc">Some os pontos das afirmações corretas.</string>
    <string name="game_sherlock_calculation_desc">Descubra como alcançar a meta usando apenas os números dados e estes operadores: + - * / ( ).</string>
    <string name="game_chain_calculation_desc">Siga as expressões matemáticas.</string>
    <string name="game_fraction_calculation_desc">Resolva as frações.</string>
    <string name="game_value_comparison_desc">Selecione a expressão com o maior valor.</string>
    <string name="game_path_finder_desc">Comece na posição marcada e siga as setas para encontrar o destino.</string>
    <string name="game_mini_sudoku_desc">Preencha a pequena grade para que cada linha, coluna e bloco contenha cada número exatamente uma vez.</string>
    <string name="game_visual_memory_desc">Memorize as formas na grade e identifique a forma oculta após o término do cronômetro.</string>
    <string name="game_pattern_sequence_desc">Encontre a próxima figura no padrão procurando formas, cores e rotações que se repetem.</string>
    <string name="game_ghost_grid_desc">Observe os blocos se iluminarem um por um e depois toque neles na mesma ordem.</string>
    <string name="game_color_confusion_desc">Toque em todas as células onde a palavra corresponde à cor da fonte e depois pressione Pronto.</string>
    <string name="game_orbit_tracker_desc">Observe as bolas destacadas e acompanhe-as enquanto se movem. Selecione os alvos originais após pararem.</string>
    <string name="game_flash_crowd_desc">Pontos piscam brevemente em cada lado. Toque no lado que tinha mais pontos. Não conte — confie no seu instinto!</string>
    <string name="game_schulte_table_desc">Toque nos números em ordem a partir de 1 o mais rápido que puder.</string>
    <string name="game_schulte_instruction">Toque nos números em ordem: 1, 2, 3...</string>
    <string name="game_mini_chess_desc">Termine o cenário de xadrez como brancas. Dê xeque-mate à CPU antes que ela dê em você.</string>
    <string name="game_lights_out_desc">Apague todas as luzes. Cada toque alterna a célula e seus quatro vizinhos.</string>
    <string name="game_sliding_puzzle_desc">Deslize as peças para o espaço vazio para colocá-las em ordem.</string>
    <string name="game_shikaku_desc">Divida toda a grade em retângulos. Cada retângulo deve conter exatamente um número, igual à sua área.</string>
    <string name="game_shikaku_howto">Arraste para desenhar um retângulo. Toque em um retângulo para removê-lo.</string>
    <string name="game_nurikabe_desc">Pinte células para formar o mar ao redor das ilhas numeradas. Cada ilha deve ter tantas células conectadas quanto o seu número, o mar deve estar conectado e não pode conter nenhum bloco 2x2.</string>
    <string name="game_nurikabe_howto">Toque ou arraste para pintar o mar. Toque numa célula pintada para apagá-la.</string>
    <string name="game_cat_queens_desc">Coloque um gato em cada linha, cada coluna e cada zona de cor. Dois gatos não podem se tocar, nem mesmo na diagonal.</string>
    <string name="game_cat_queens_howto">Toque numa célula para colocar ou remover um gato.</string>
    <string name="game_knot_desc">Conecte cada par de pontos coloridos com um caminho. Os caminhos não podem se cruzar e juntos devem cobrir todas as células.</string>
    <string name="game_knot_howto">Arraste a partir de um ponto para desenhar o seu caminho. Toque num caminho para apagá-lo.</string>
    <string name="cat_queens_error_row">Apenas um gato por linha</string>
