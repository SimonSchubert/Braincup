    <!-- Game types - descriptions -->
    <string name="game_anomaly_puzzle_desc">Βρείτε το σχήμα που ξεχωρίζει. Λάβετε υπόψη τόσο το χρώμα όσο και το σχήμα κάθε πλακιδίου.</string>
    <string name="game_mental_calculation_desc">Ακολουθήστε τις μαθηματικές παραστάσεις. Χρησιμοποιήστε το αποτέλεσμα ως βάση για τον επόμενο υπολογισμό.</string>
    <string name="game_colored_shapes_desc">Προσθέστε τους βαθμούς από τις σωστές παραστάσεις.</string>
    <string name="game_sherlock_calculation_desc">Βρείτε πώς να φτάσετε στο στόχο χρησιμοποιώντας μόνο τους δεδομένους αριθμούς και αυτούς τους τελεστές: + - * / ( ).</string>
    <string name="game_chain_calculation_desc">Ακολουθήστε τις μαθηματικές παραστάσεις.</string>
    <string name="game_fraction_calculation_desc">Λύστε τα κλάσματα.</string>
    <string name="game_value_comparison_desc">Επιλέξτε την παράσταση με την υψηλότερη τιμή.</string>
    <string name="game_path_finder_desc">Ξεκινήστε από τη σημειωμένη θέση και ακολουθήστε τα βέλη για να βρείτε τον προορισμό.</string>
    <string name="game_mini_sudoku_desc">Γεμίστε το μικρό πλέγμα έτσι ώστε κάθε γραμμή, στήλη και μπλοκ να περιέχει κάθε αριθμό ακριβώς μία φορά.</string>
    <string name="game_visual_memory_desc">Απομνημονεύστε τα σχήματα στο πλέγμα, και μετά εντοπίστε το κρυμμένο σχήμα μετά τη λήξη της διορίας.</string>
    <string name="game_pattern_sequence_desc">Βρείτε το επόμενο σχήμα στο μοτίβο αναζητώντας επαναλαμβανόμενα σχήματα, χρώματα και περιστροφές.</string>
    <string name="game_ghost_grid_desc">Παρακολουθήστε τα πλακίδια να φωτίζονται ένα προς ένα, και μετά πατήστε τα ξανά με την ίδια σειρά.</string>
    <string name="game_color_confusion_desc">Πατήστε όλα τα κελιά όπου η λέξη ταιριάζει με το χρώμα της γραμματοσειράς της, και μετά πατήστε Τέλος.</string>
    <string name="game_orbit_tracker_desc">Παρακολουθήστε τις φωτεινές μπάλες και μετά το πώς κινούνται. Επιλέξτε τους αρχικούς στόχους αφού σταματήσουν.</string>
    <string name="game_flash_crowd_desc">Κουκκίδες αναβοσβήνουν για λίγο σε κάθε πλευρά. Πατήστε την πλευρά που είχε περισσότερες κουκκίδες. Μην μετράτε - μόνο ένστικτο!</string>
    <string name="game_schulte_table_desc">Πατήστε τους αριθμούς με τη σειρά από το 1 και μετά, όσο πιο γρήγορα μπορείτε.</string>
    <string name="game_schulte_instruction">Πατήστε τους αριθμούς με τη σειρά: 1, 2, 3...</string>
    <string name="game_mini_chess_desc">Ολοκληρώστε το σενάριο σκακιού με τα λευκά. Κάντε ματ στη CPU πριν σας κάνει ματ εκείνη.</string>
    <string name="game_lights_out_desc">Σβήστε όλα τα φώτα. Κάθε πάτημα εναλλάσσει το κελί και τα τέσσερα γειτονικά του.</string>
    <string name="game_sliding_puzzle_desc">Σύρετε τα πλακίδια στον κενό χώρο για να τα τοποθετήσετε στη σειρά.</string>
    <string name="game_shikaku_desc">Χωρίστε ολόκληρο το πλέγμα σε ορθογώνια. Κάθε ορθογώνιο πρέπει να περιέχει ακριβώς έναν αριθμό, ίσο με το εμβαδόν του.</string>
    <string name="game_shikaku_howto">Σύρετε για να σχεδιάσετε ένα ορθογώνιο. Πατήστε ένα ορθογώνιο για να το αφαιρέσετε.</string>
    <string name="game_nurikabe_desc">Βάψτε κελιά για να χτίσετε τη θάλασσα γύρω από αριθμημένα νησιά. Κάθε νησί πρέπει να έχει τόσα συνδεδεμένα κελιά όσο ο αριθμός του, η θάλασσα πρέπει να είναι συνεχόμενη και να μην περιέχει τετράγωνο 2x2.</string>
    <string name="game_nurikabe_howto">Πατήστε ή σύρετε για να βάψετε τη θάλασσα. Πατήστε ένα γεμάτο κελί για να το καθαρίσετε.</string>
    <string name="game_cat_queens_desc">Τοποθετήστε μία γάτα σε κάθε γραμμή, κάθε στήλη και κάθε χρωματική ζώνη. Καμία γάτα δεν επιτρέπεται να αγγίζει άλλη, ούτε διαγώνια.</string>
    <string name="game_cat_queens_howto">Πατήστε ένα κελί για να τοποθετήσετε ή να αφαιρέσετε μια γάτα.</string>
    <string name="game_knot_desc">Συνδέστε κάθε ζεύγος χρωματιστών κουκκίδων με μια διαδρομή. Οι διαδρομές δεν επιτρέπεται να διασταυρώνονται και μαζί πρέπει να καλύπτουν κάθε κελί.</string>
    <string name="game_knot_howto">Σύρετε από μια κουκκίδα για να σχεδιάσετε τη διαδρομή της. Πατήστε μια διαδρομή για να την καθαρίσετε.</string>
    <string name="game_solo_chess_desc">Αιχμαλώτισε τα κομμάτια ένα προς ένα μέχρι να μείνει μόνο ο βασιλιάς. Κάθε κίνηση πρέπει να αιχμαλωτίζει και κανένα κομμάτι δεν μπορεί να αιχμαλωτίσει πάνω από δύο φορές.</string>
    <string name="game_solo_chess_howto">Πάτησε ένα κομμάτι και μετά ένα που μπορεί να αιχμαλωτίσει. Ο βασιλιάς δεν αιχμαλωτίζεται και πρέπει να μείνει τελευταίος.</string>
