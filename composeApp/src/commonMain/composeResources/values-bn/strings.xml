    <!-- Game types - descriptions -->
    <string name="game_anomaly_puzzle_desc">আলাদা চিত্রটি খুঁজুন। প্রতিটি চিত্রের রঙ এবং আকৃতি উভয়ই বিবেচনা করুন।</string>
    <string name="game_mental_calculation_desc">গাণিতিক এক্সপ্রেশনগুলি অনুসরণ করুন। পরবর্তী গণনার ভিত্তি হিসাবে ফলাফল ব্যবহার করুন।</string>
    <string name="game_colored_shapes_desc">সঠিক বিবৃতির পয়েন্ট যোগ করুন।</string>
    <string name="game_sherlock_calculation_desc">শুধুমাত্র প্রদত্ত সংখ্যা এবং এই অপারেটরগুলি ব্যবহার করে লক্ষ্যে পৌঁছানোর উপায় খুঁজুন: + - * / ( )।</string>
    <string name="game_chain_calculation_desc">গাণিতিক এক্সপ্রেশনগুলি অনুসরণ করুন।</string>
    <string name="game_fraction_calculation_desc">ভগ্নাংশগুলি সমাধান করুন।</string>
    <string name="game_value_comparison_desc">সর্বোচ্চ মানের এক্সপ্রেশনটি নির্বাচন করুন।</string>
    <string name="game_path_finder_desc">চিহ্নিত অবস্থান থেকে শুরু করুন এবং গন্তব্য খুঁজতে তীরগুলি অনুসরণ করুন।</string>
    <string name="game_mini_sudoku_desc">ছোট গ্রিডটি পূরণ করুন যাতে প্রতিটি সারি, কলাম এবং ব্লকে প্রতিটি সংখ্যা ঠিক একবার থাকে।</string>
    <string name="game_visual_memory_desc">গ্রিডে আকৃতিগুলি মুখস্থ করুন, তারপর টাইমার শেষ হওয়ার পরে লুকানো আকৃতিটি সনাক্ত করুন।</string>
    <string name="game_pattern_sequence_desc">পুনরাবৃত্ত আকার, রঙ এবং ঘূর্ণন খুঁজে প্যাটার্নের পরবর্তী চিত্রটি খুঁজুন।</string>
    <string name="game_ghost_grid_desc">টাইলগুলো একে একে জ্বলতে দেখুন, তারপর একই ক্রমে ট্যাপ করুন।</string>
    <string name="game_color_confusion_desc">যেসব ঘরে শব্দটি ফন্টের রঙের সাথে মেলে সেগুলোতে ট্যাপ করুন, তারপর সম্পন্ন চাপুন।</string>
    <string name="game_orbit_tracker_desc">হাইলাইট করা বলগুলো দেখুন, তারপর সেগুলো নড়াচড়ার সময় ট্র্যাক করুন। থামার পরে মূল লক্ষ্যগুলো নির্বাচন করুন।</string>
    <string name="game_flash_crowd_desc">প্রতিটি পাশে সংক্ষেপে বিন্দু জ্বলে। যে পাশে বেশি বিন্দু ছিল সেদিকে ট্যাপ করুন। গুনবেন না — আপনার অনুভূতিতে বিশ্বাস করুন!</string>
    <string name="game_schulte_table_desc">১ থেকে শুরু করে যত দ্রুত সম্ভব ক্রমানুসারে সংখ্যাগুলিতে ট্যাপ করুন।</string>
