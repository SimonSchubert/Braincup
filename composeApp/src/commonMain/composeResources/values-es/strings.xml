    <!-- Game types - descriptions -->
    <string name="game_anomaly_puzzle_desc">Encuentra la figura que destaca. Considera tanto el color como la forma de cada figura.</string>
    <string name="game_mental_calculation_desc">Sigue las expresiones matemáticas. Usa el resultado como base para el siguiente cálculo.</string>
    <string name="game_colored_shapes_desc">Suma los puntos de las afirmaciones correctas.</string>
    <string name="game_sherlock_calculation_desc">Encuentra cómo alcanzar la meta usando solo los números dados y estos operadores: + - * / ( ).</string>
    <string name="game_chain_calculation_desc">Sigue las expresiones matemáticas.</string>
    <string name="game_fraction_calculation_desc">Resuelve las fracciones.</string>
    <string name="game_value_comparison_desc">Selecciona la expresión con el valor más alto.</string>
    <string name="game_path_finder_desc">Comienza en la posición marcada y sigue las flechas para encontrar el destino.</string>
    <string name="game_grid_solver_desc">Rellena los números que faltan para que cada fila y columna sume los totales dados.</string>
    <string name="game_visual_memory_desc">Memoriza las formas en la cuadrícula, luego identifica la forma oculta cuando termine el temporizador.</string>
    <string name="game_pattern_sequence_desc">Encuentra la siguiente figura en el patrón buscando formas, colores y rotaciones que se repiten.</string>
    <string name="game_ghost_grid_desc">Observa cómo se iluminan las casillas una por una y luego tócalas en el mismo orden.</string>
    <string name="game_color_confusion_desc">Toca todas las celdas donde la palabra coincida con el color de la fuente y luego pulsa Listo.</string>
    <string name="game_orbit_tracker_desc">Observa las bolas resaltadas y luego síguelas mientras se mueven. Selecciona los objetivos originales después de que se detengan.</string>
    <string name="game_flash_crowd_desc">Los puntos parpadean brevemente en cada lado. Toca el lado que tenía más puntos. ¡No cuentes, confía en tu instinto!</string>
    <string name="game_what_comes_next">¿Qué sigue?</string>
