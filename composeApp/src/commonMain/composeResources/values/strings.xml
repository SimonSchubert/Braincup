    <!-- Game types - descriptions -->
    <string name="game_anomaly_puzzle_desc">Find the figure that stands out. Consider both the color and shape of each figure.</string>
    <string name="game_mental_calculation_desc">Follow the mathematical expressions. Use the result as the base for the next calculation.</string>
    <string name="game_colored_shapes_desc">Add up the points from the correct statements.</string>
    <string name="game_sherlock_calculation_desc">Find how to reach the goal using only the given numbers and these operators: + - * / ( ).</string>
    <string name="game_chain_calculation_desc">Follow the mathematical expressions.</string>
    <string name="game_fraction_calculation_desc">Solve the fractions.</string>
    <string name="game_value_comparison_desc">Select the expression with the highest value.</string>
    <string name="game_path_finder_desc">Start at the marked position and follow the arrows to find the destination.</string>
    <string name="game_mini_sudoku_desc">Fill the small grid so every row, column and block contains each number exactly once.</string>
    <string name="game_visual_memory_desc">Memorize the shapes on the grid, then identify the hidden shape after the timer ends.</string>
    <string name="game_pattern_sequence_desc">Find the next figure in the pattern by looking for repeating shapes, colors, and rotations.</string>
    <string name="game_ghost_grid_desc">Watch the tiles light up one by one, then tap them back in the same order.</string>
    <string name="game_color_confusion_desc">Tap all cells where the word matches its font color, then press Done.</string>
    <string name="game_orbit_tracker_desc">Watch the highlighted balls, then track them as they move. Select the original targets after they stop.</string>
    <string name="game_flash_crowd_desc">Dots flash briefly on each side. Tap the side that had more dots. Don't count — trust your instinct!</string>
    <string name="game_schulte_table_desc">Tap the numbers in order from 1 upwards as fast as you can.</string>
    <string name="game_schulte_instruction">Tap the numbers in order: 1, 2, 3...</string>
    <string name="game_mini_chess_desc">Finish the chess scenario as white. Checkmate the CPU before it checkmates you.</string>
    <string name="game_lights_out_desc">Turn off every light. Each tap toggles the cell and its four neighbours.</string>
    <string name="game_sliding_puzzle_desc">Slide tiles into the empty space to put them in order.</string>
    <string name="game_shikaku_desc">Divide the whole grid into rectangles. Each rectangle must contain exactly one number, equal to its area.</string>
    <string name="game_shikaku_howto">Drag to draw a rectangle. Tap a rectangle to remove it.</string>
    <string name="game_nurikabe_desc">Paint cells to build the sea around numbered islands. Each island must have as many connected cells as its number, the sea must be connected, and it must contain no 2x2 block.</string>
    <string name="game_nurikabe_howto">Tap or drag to paint the sea. Tap a filled cell to clear it.</string>
    <string name="game_cat_queens_desc">Place one cat in every row, every column and every color zone. No two cats may touch, not even diagonally.</string>
    <string name="game_cat_queens_howto">Tap a cell to place or remove a cat.</string>
    <string name="game_knot_desc">Connect each pair of colored dots with a path. Paths may not cross, and together they must cover every cell.</string>
    <string name="game_knot_howto">Drag from a dot to draw its path. Tap a path to clear it.</string>
    <string name="game_solo_chess_desc">Capture the pieces one by one until only the king is left. Every move must capture, and no piece may capture more than twice.</string>
    <string name="game_solo_chess_howto">Tap a piece, then tap one it can capture. The king can't be captured and must be the last piece left.</string>
