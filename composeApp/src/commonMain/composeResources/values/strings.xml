    <!-- Game types - descriptions -->
    <string name="game_anomaly_puzzle_desc">Find the figure that stands out. Consider both the color and shape of each figure.</string>
    <string name="game_mental_calculation_desc">Follow the mathematical expressions. Use the result as the base for the next calculation.</string>
    <string name="game_colored_shapes_desc">Add up the points from the correct statements.</string>
    <string name="game_sherlock_calculation_desc">Find how to reach the goal using only the given numbers and these operators: + - * / ( ).</string>
    <string name="game_chain_calculation_desc">Follow the mathematical expressions.</string>
    <string name="game_fraction_calculation_desc">Solve the fractions.</string>
    <string name="game_value_comparison_desc">Select the expression with the highest value.</string>
    <string name="game_path_finder_desc">Start at the marked position and follow the arrows to find the destination.</string>
    <string name="game_grid_solver_desc">Fill in the missing numbers so that each row and column sums to the given totals.</string>
    <string name="game_visual_memory_desc">Memorize the shapes on the grid, then identify the hidden shape after the timer ends.</string>
    <string name="game_pattern_sequence_desc">Find the next figure in the pattern by looking for repeating shapes, colors, and rotations.</string>
    <string name="game_ghost_grid_desc">Watch the tiles light up one by one, then tap them back in the same order.</string>
    <string name="game_color_confusion_desc">Tap all cells where the word matches its font color, then press Done.</string>
    <string name="game_orbit_tracker_desc">Watch the highlighted balls, then track them as they move. Select the original targets after they stop.</string>
    <string name="game_flash_crowd_desc">Dots flash briefly on each side. Tap the side that had more dots. Don't count — trust your instinct!</string>
